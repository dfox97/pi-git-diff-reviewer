{
  "name": "pi-diff-review-wsl",
  "version": "0.4.0",
  "description": "Native diff review window for pi and opencode, with WSL2 support via Windows WebView2",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "opencode",
    "opencode-plugin",
    "diff",
    "review",
    "wsl",
    "glimpse"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dfox97/pi-git-diff-reviewer"
  },
  "license": "MIT",
  "bin": {
    "diff-review": "./bin/diff-review"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "types",
    "web"
  ],
  "scripts": {
    "check": "tsgo --noEmit",
    "build": "tsgo -p tsconfig.build.json",
    "dev:window": "tsx scripts/dev-window.ts",
    "vendor": "node scripts/vendor.mjs",
    "prepublishOnly": "npm run build"
  },
  "pi": {
    "extensions": [
      "./src/bindings/pi.ts"
    ]
  },
  "dependencies": {
    "glimpseui": "^0.8.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-tui": "^0.79.6",
    "@opencode-ai/plugin": "^1.3.0",
    "@opencode-ai/sdk": "^1.3.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260313.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2"
  }
}
